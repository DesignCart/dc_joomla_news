<?xml version="1.0" encoding="utf-8"?>
<extension type="module" client="site" method="upgrade">
    <name>MOD_DC_NEWS</name>
    <author>Paweł Nosko</author>
    <creationDate>2026-04</creationDate>
    <copyright>(C) 2026 Design Cart / Paweł Nosko</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <authorEmail>info@designcart.pl</authorEmail>
    <authorUrl>https://designcart.pl</authorUrl>
    <version>1.0.0</version>
    <description>MOD_DC_NEWS_XML_DESCRIPTION</description>
    <files>
        <filename module="mod_dc_news">mod_dc_news.php</filename>
        <filename>helper.php</filename>
        <folder>tmpl</folder>
    </files>

    <languages>
        <language tag="en-GB">language/en-GB/mod_dc_news.ini</language>
        <language tag="en-GB">language/en-GB/mod_dc_news.sys.ini</language>
        <language tag="pl-PL">language/pl-PL/mod_dc_news.ini</language>
        <language tag="pl-PL">language/pl-PL/mod_dc_news.sys.ini</language>
    </languages>

    <config>
        <fields name="params">
            <fieldset name="general" label="MOD_DC_NEWS_TAB_GENERAL">
                <field
                    name="catid"
                    type="category"
                    extension="com_content"
                    multiple="true"
                    label="MOD_DC_NEWS_FIELD_CATEGORIES_LABEL"
                    description="MOD_DC_NEWS_FIELD_CATEGORIES_DESC"
                />
                <field
                    name="featured_only"
                    type="radio"
                    default="0"
                    label="MOD_DC_NEWS_FIELD_FEATURED_ONLY_LABEL"
                    class="btn-group btn-group-yesno"
                    description="MOD_DC_NEWS_FIELD_FEATURED_ONLY_DESC"
                >
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
                <field
                    name="count"
                    type="number"
                    default="6"
                    min="1"
                    max="50"
                    step="1"
                    label="MOD_DC_NEWS_FIELD_COUNT_LABEL"
                    description="MOD_DC_NEWS_FIELD_COUNT_DESC"
                />
                <field name="show_title" type="radio" default="1" label="MOD_DC_NEWS_FIELD_SHOW_TITLE_LABEL" class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
                <field name="title_tag" type="list" default="h3" label="MOD_DC_NEWS_FIELD_TITLE_TAG_LABEL">
                    <option value="h1">H1</option>
                    <option value="h2">H2</option>
                    <option value="h3">H3</option>
                    <option value="h4">H4</option>
                    <option value="h5">H5</option>
                    <option value="h6">H6</option>
                </field>
                <field name="show_intro" type="radio" default="1" label="MOD_DC_NEWS_FIELD_SHOW_INTRO_LABEL" class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
                <field name="show_readmore" type="radio" default="1" label="MOD_DC_NEWS_FIELD_SHOW_READMORE_LABEL" class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
                <field
                    name="readmore_text"
                    type="text"
                    default="Czytaj więcej"
                    label="MOD_DC_NEWS_FIELD_READMORE_TEXT_LABEL"
                    description="MOD_DC_NEWS_FIELD_READMORE_TEXT_DESC"
                />
                <field name="show_tags" type="radio" default="1" label="MOD_DC_NEWS_FIELD_SHOW_TAGS_LABEL" class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
                <field name="show_image" type="radio" default="1" label="MOD_DC_NEWS_FIELD_SHOW_IMAGE_LABEL" class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
                <field name="image_position" type="list" default="top" label="MOD_DC_NEWS_FIELD_IMAGE_POSITION_LABEL">
                    <option value="left">MOD_DC_NEWS_IMAGE_LEFT</option>
                    <option value="top">MOD_DC_NEWS_IMAGE_TOP</option>
                </field>
                <field
                    name="image_width_value"
                    type="number"
                    default="38"
                    min="1"
                    max="1000"
                    step="1"
                    label="MOD_DC_NEWS_FIELD_IMAGE_WIDTH_VALUE_LABEL"
                />
                <field name="image_width_unit" type="list" default="%" label="MOD_DC_NEWS_FIELD_IMAGE_WIDTH_UNIT_LABEL">
                    <option value="%">%</option>
                    <option value="px">px</option>
                </field>
                <field
                    name="grid_columns"
                    type="number"
                    default="3"
                    min="1"
                    max="6"
                    step="1"
                    label="MOD_DC_NEWS_FIELD_GRID_COLUMNS_LABEL"
                />
                <field name="image_shape" type="list" default="1:1" label="MOD_DC_NEWS_FIELD_IMAGE_SHAPE_LABEL">
                    <option value="circle">MOD_DC_NEWS_IMAGE_SHAPE_CIRCLE</option>
                    <option value="1:1">MOD_DC_NEWS_IMAGE_SHAPE_1_1</option>
                    <option value="1:2">MOD_DC_NEWS_IMAGE_SHAPE_1_2</option>
                    <option value="2:3">MOD_DC_NEWS_IMAGE_SHAPE_2_3</option>
                    <option value="1:3">MOD_DC_NEWS_IMAGE_SHAPE_1_3</option>
                    <option value="3:1">MOD_DC_NEWS_IMAGE_SHAPE_3_1</option>
                    <option value="3:2">MOD_DC_NEWS_IMAGE_SHAPE_3_2</option>
                    <option value="2:1">MOD_DC_NEWS_IMAGE_SHAPE_2_1</option>
                </field>
            </fieldset>

            <fieldset name="appearance" label="MOD_DC_NEWS_TAB_APPEARANCE">
                <field name="item_bg_color" type="color" default="#ffffff" label="MOD_DC_NEWS_FIELD_ITEM_BG_COLOR_LABEL" />
                <field name="title_color" type="color" default="#111111" label="MOD_DC_NEWS_FIELD_TITLE_COLOR_LABEL" />
                <field name="title_font_size" type="number" default="20" min="8" max="72" label="MOD_DC_NEWS_FIELD_TITLE_FONT_SIZE_LABEL" />
                <field name="title_font_weight" type="list" default="700" label="MOD_DC_NEWS_FIELD_TITLE_FONT_WEIGHT_LABEL">
                    <option value="200">200</option><option value="300">300</option><option value="400">400</option><option value="500">500</option><option value="600">600</option><option value="700">700</option><option value="800">800</option><option value="900">900</option>
                </field>
                <field name="title_uppercase" type="radio" default="0" label="MOD_DC_NEWS_FIELD_TITLE_UPPERCASE_LABEL" class="btn-group btn-group-yesno">
                    <option value="1">JYES</option><option value="0">JNO</option>
                </field>

                <field name="intro_color" type="color" default="#555555" label="MOD_DC_NEWS_FIELD_INTRO_COLOR_LABEL" />
                <field name="intro_font_size" type="number" default="15" min="8" max="72" label="MOD_DC_NEWS_FIELD_INTRO_FONT_SIZE_LABEL" />
                <field name="intro_font_weight" type="list" default="400" label="MOD_DC_NEWS_FIELD_INTRO_FONT_WEIGHT_LABEL">
                    <option value="200">200</option><option value="300">300</option><option value="400">400</option><option value="500">500</option><option value="600">600</option><option value="700">700</option><option value="800">800</option><option value="900">900</option>
                </field>
                <field name="intro_uppercase" type="radio" default="0" label="MOD_DC_NEWS_FIELD_INTRO_UPPERCASE_LABEL" class="btn-group btn-group-yesno">
                    <option value="1">JYES</option><option value="0">JNO</option>
                </field>

                <field name="tag_color" type="color" default="#ffffff" label="MOD_DC_NEWS_FIELD_TAG_COLOR_LABEL" />
                <field name="tag_bg_color" type="color" default="#1e73be" label="MOD_DC_NEWS_FIELD_TAG_BG_COLOR_LABEL" />
                <field name="tag_color_hover" type="color" default="#ffffff" label="MOD_DC_NEWS_FIELD_TAG_COLOR_HOVER_LABEL" />
                <field name="tag_bg_color_hover" type="color" default="#155a91" label="MOD_DC_NEWS_FIELD_TAG_BG_COLOR_HOVER_LABEL" />
                <field name="tag_font_size" type="number" default="12" min="8" max="72" label="MOD_DC_NEWS_FIELD_TAG_FONT_SIZE_LABEL" />
                <field name="tag_font_weight" type="list" default="600" label="MOD_DC_NEWS_FIELD_TAG_FONT_WEIGHT_LABEL">
                    <option value="200">200</option><option value="300">300</option><option value="400">400</option><option value="500">500</option><option value="600">600</option><option value="700">700</option><option value="800">800</option><option value="900">900</option>
                </field>
                <field name="tag_uppercase" type="radio" default="0" label="MOD_DC_NEWS_FIELD_TAG_UPPERCASE_LABEL" class="btn-group btn-group-yesno">
                    <option value="1">JYES</option><option value="0">JNO</option>
                </field>

                <field name="button_color" type="color" default="#ffffff" label="MOD_DC_NEWS_FIELD_BUTTON_COLOR_LABEL" />
                <field name="button_bg_color" type="color" default="#000000" label="MOD_DC_NEWS_FIELD_BUTTON_BG_COLOR_LABEL" />
                <field name="button_color_hover" type="color" default="#ffffff" label="MOD_DC_NEWS_FIELD_BUTTON_COLOR_HOVER_LABEL" />
                <field name="button_bg_color_hover" type="color" default="#333333" label="MOD_DC_NEWS_FIELD_BUTTON_BG_COLOR_HOVER_LABEL" />
                <field name="button_font_size" type="number" default="14" min="8" max="72" label="MOD_DC_NEWS_FIELD_BUTTON_FONT_SIZE_LABEL" />
                <field name="button_font_weight" type="list" default="700" label="MOD_DC_NEWS_FIELD_BUTTON_FONT_WEIGHT_LABEL">
                    <option value="200">200</option><option value="300">300</option><option value="400">400</option><option value="500">500</option><option value="600">600</option><option value="700">700</option><option value="800">800</option><option value="900">900</option>
                </field>
                <field name="button_uppercase" type="radio" default="0" label="MOD_DC_NEWS_FIELD_BUTTON_UPPERCASE_LABEL" class="btn-group btn-group-yesno">
                    <option value="1">JYES</option><option value="0">JNO</option>
                </field>
            </fieldset>
        </fields>
    </config>
</extension>
